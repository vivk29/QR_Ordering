rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Restaurants: Anyone can read, only admin can write
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Menu Items: Anyone can read, only admin can write
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tables: Anyone can read, only admin can write
    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: 
    // Customers can create and read their own (if we had auth for them)
    // For QR ordering, we often allow public creation but restricted reading
    match /orders/{orderId} {
      allow create: if true;
      allow read: if true; // In a real app, you might restrict this to the specific table session
      allow update, delete: if isAdmin();
    }

    // Users: Only the user can read their own profile, admins can read all
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
